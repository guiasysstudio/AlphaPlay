<Window MinHeight="520" x:Class="AlphaPlay.DownloadUpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Baixar atualização" Height="330" Width="520"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        Background="#07101F">
    <Window.Resources>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1A3767"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="18" Padding="22" CornerRadius="18" Background="#0D172A" BorderBrush="#253C6B" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Baixando atualização" Foreground="White" FontSize="24" FontWeight="Bold"/>
                <TextBlock x:Name="TxtFileName" Text="-" Foreground="#B7C8E8" FontSize="13" TextWrapping="Wrap" Margin="0,8,0,0"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,26,0,20">
                <ProgressBar x:Name="ProgressDownload" Height="18" Minimum="0" Maximum="100" Value="0"/>
                <TextBlock x:Name="TxtProgress" Text="Preparando download..." Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,14,0,0"/>
                <TextBlock x:Name="TxtStatus" Text="Aguarde." Foreground="#B7C8E8" TextWrapping="Wrap" Margin="0,8,0,0"/>
            </StackPanel>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="BtnCancel" Grid.Column="1" Style="{StaticResource ActionButton}" Width="110" Content="Cancelar" Click="BtnCancel_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>

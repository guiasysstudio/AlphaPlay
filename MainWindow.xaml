<Window x:Class="AlphaPlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        Title="AlphaPlay"
        Icon="assets/brand/app_icon.ico"
        Height="780"
        Width="1240"
        MinHeight="690"
        MinWidth="1080"
        WindowStartupLocation="CenterScreen"
        Background="#070B1A"
        Closing="Window_Closing">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <LinearGradientBrush x:Key="AppBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#070B1A" Offset="0"/>
            <GradientStop Color="#10172D" Offset="0.55"/>
            <GradientStop Color="#071D35" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="CardBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#121A2E" Offset="0"/>
            <GradientStop Color="#17233C" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="AccentBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#00D9FF" Offset="0"/>
            <GradientStop Color="#006BFF" Offset="0.55"/>
            <GradientStop Color="#8B2DFF" Offset="1"/>
        </LinearGradientBrush>

        <SolidColorBrush x:Key="LineBrush" Color="#24314F"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#9FB0D0"/>

        <Style TargetType="Image">
            <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style x:Key="TitleText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="18"/>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="BorderBrush" Value="#223055"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="22" ShadowDepth="0" Opacity="0.25"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1A2744"/>
            <Setter Property="BorderBrush" Value="#314061"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#22365E"/>
                                <Setter Property="BorderBrush" Value="#00D9FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#16223E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#05356A"/>
            <Setter Property="BorderBrush" Value="#00BFFB"/>
        </Style>

        <Style x:Key="IconOnlyButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="999">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#20385F"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#00D9FF"/>
                                <Setter TargetName="Root" Property="BorderThickness" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#0B7DAD"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#0C1426"/>
            <Setter Property="BorderBrush" Value="#26365F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="CaretBrush" Value="#00D9FF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#00D9FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Background" Value="#F3F7FF"/>
            <Setter Property="BorderBrush" Value="#4FDFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,2"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="SliderRepeatButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Height="5" CornerRadius="3" Background="{TemplateBinding Background}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SliderThumbStyle" TargetType="Thumb">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Grid>
                            <Ellipse Fill="#E8FBFF" Stroke="#00D9FF" StrokeThickness="1.2">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#00D9FF" BlurRadius="10" ShadowDepth="0" Opacity="0.45"/>
                                </Ellipse.Effect>
                            </Ellipse>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Foreground" Value="#00D9FF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Track x:Name="PART_Track" Height="18">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" Background="#00D9FF" Style="{StaticResource SliderRepeatButtonStyle}"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Background="#394968" Style="{StaticResource SliderRepeatButtonStyle}"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SliderThumbStyle}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#0A1121"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#24314F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
        </Style>

        <Style x:Key="MoveIconButton" TargetType="Button">
            <Setter Property="Height" Value="18"/>
            <Setter Property="Width" Value="18"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#22365E"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter Property="Background" Value="#0B5B9D"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16" Background="{StaticResource AppBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="210"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="22" Padding="12" Margin="0,0,0,12" BorderBrush="#203B6B" BorderThickness="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#070B1A" Offset="0"/>
                    <GradientStop Color="#0C2C50" Offset="0.52"/>
                    <GradientStop Color="#24124F" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0" Source="assets/brand/header_banner_clean.png" Height="120" Width="250" Stretch="Uniform" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Player de áudio e vídeo para sequências ao vivo" Foreground="#D8F7FF" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtMusicFolder" Text="Pasta das músicas:" Foreground="#9FB0D0" FontSize="12" Margin="0,5,0,0" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="BtnSettings" Style="{StaticResource ModernButton}" Width="128" Margin="6,0,0,0" Click="BtnSettings_Click">
                        <StackPanel Orientation="Horizontal"><Image Source="assets/icons/Configuracao.png" Width="16" Height="16" Margin="0,0,7,0"/><TextBlock Text="Configurações"/></StackPanel>
                    </Button>
                    <Button x:Name="BtnOpenMusicFolder" Style="{StaticResource ModernButton}" Width="150" Margin="6,0,0,0" Click="BtnOpenMusicFolder_Click">
                        <StackPanel Orientation="Horizontal"><Image Source="assets/icons/Abrir_Pasta.png" Width="16" Height="16" Margin="0,0,7,0"/><TextBlock Text="Abrir pasta"/></StackPanel>
                    </Button>
                    <Button x:Name="BtnReload" Style="{StaticResource AccentButton}" Width="118" Margin="6,0,0,0" Click="BtnReload_Click">
                        <StackPanel Orientation="Horizontal"><Image Source="assets/icons/Recarregar.png" Width="16" Height="16" Margin="0,0,7,0"/><TextBlock Text="Recarregar"/></StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="560"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Biblioteca de músicas" Style="{StaticResource TitleText}" Margin="0,0,0,12"/>

                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="92"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtSearch" Grid.Column="0" Height="38" FontSize="14" TextChanged="TxtSearch_TextChanged"/>
                        <Button x:Name="BtnClearSearch" Grid.Column="1" Style="{StaticResource ModernButton}" Height="38" Margin="8,0,0,0" Click="BtnClearSearch_Click">
                            <StackPanel Orientation="Horizontal"><Image Source="assets/icons/Limpar.png" Width="14" Height="14" Margin="0,0,6,0"/><TextBlock Text="Limpar"/></StackPanel>
                        </Button>
                    </Grid>

                    <ListBox x:Name="ListLibrary" Grid.Row="2" MouseDoubleClick="ListLibrary_MouseDoubleClick" SelectionChanged="ListLibrary_SelectionChanged" DisplayMemberPath="Title">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="8,5"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#142A4A"/></Trigger>
                                                <Trigger Property="IsSelected" Value="True"><Setter TargetName="Bd" Property="Background" Value="#063A63"/></Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <DockPanel Grid.Row="3" Margin="0,10,0,0">
                        <TextBlock x:Name="TxtLibraryCount" DockPanel.Dock="Left" Text="0 músicas encontradas" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                        <Button x:Name="BtnAddToSequence" DockPanel.Dock="Right" Style="{StaticResource AccentButton}" Width="195" Height="36" Click="BtnAddToSequence_Click">
                            <StackPanel Orientation="Horizontal"><Image Source="assets/icons/Adicionar.png" Width="16" Height="16" Margin="0,0,7,0"/><TextBlock Text="Adicionar à sequência"/></StackPanel>
                        </Button>
                    </DockPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Sequência" Style="{StaticResource TitleText}" Margin="0,0,0,12"/>

                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <ComboBox x:Name="ComboSavedSequences" Height="32" FontSize="12" DisplayMemberPath="Name" SelectionChanged="ComboSavedSequences_SelectionChanged"/>
                        <UniformGrid Grid.Row="1" Columns="5" Margin="0,7,0,0">
                            <Button Style="{StaticResource ModernButton}" Height="30" Margin="0,0,4,0" Click="BtnNewSequence_Click"><StackPanel Orientation="Horizontal"><Image Source="assets/icons/Nova.png" Width="14" Height="14" Margin="0,0,5,0"/><TextBlock Text="Nova"/></StackPanel></Button>
                            <Button Style="{StaticResource ModernButton}" Height="30" Margin="0,0,4,0" Click="BtnSaveSequence_Click"><StackPanel Orientation="Horizontal"><Image Source="assets/icons/Salvar.png" Width="14" Height="14" Margin="0,0,5,0"/><TextBlock Text="Salvar"/></StackPanel></Button>
                            <Button Style="{StaticResource ModernButton}" Height="30" Margin="0,0,4,0" Click="BtnSaveSequenceAs_Click"><StackPanel Orientation="Horizontal"><Image Source="assets/icons/Salvar_Como.png" Width="14" Height="14" Margin="0,0,5,0"/><TextBlock Text="Salvar como" FontSize="11"/></StackPanel></Button>
                            <Button Style="{StaticResource ModernButton}" Height="30" Margin="0,0,4,0" Click="BtnLoadSequence_Click"><StackPanel Orientation="Horizontal"><Image Source="assets/icons/Carregar_Importar.png" Width="14" Height="14" Margin="0,0,5,0"/><TextBlock Text="Carregar"/></StackPanel></Button>
                            <Button Style="{StaticResource ModernButton}" Height="30" Click="BtnDeleteSequence_Click"><StackPanel Orientation="Horizontal"><Image Source="assets/icons/Excluir.png" Width="14" Height="14" Margin="0,0,5,0"/><TextBlock Text="Excluir"/></StackPanel></Button>
                        </UniformGrid>
                    </Grid>

                    <ListBox x:Name="ListSequence" Grid.Row="2"
                             MouseDoubleClick="ListSequence_MouseDoubleClick"
                             SelectionChanged="ListSequence_SelectionChanged"
                             PreviewMouseLeftButtonDown="ListSequence_PreviewMouseLeftButtonDown"
                             MouseMove="ListSequence_MouseMove"
                             Drop="ListSequence_Drop"
                             AllowDrop="True">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="3"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="9" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#142A4A"/></Trigger>
                                                <Trigger Property="IsSelected" Value="True"><Setter TargetName="Bd" Property="Background" Value="#102F56"/></Trigger>
                                                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#0B5B9D"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,1" MinHeight="26">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22"/>
                                        <ColumnDefinition Width="22"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="22"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Style="{StaticResource MoveIconButton}" Visibility="{Binding CanMoveUp, Converter={StaticResource BoolToVisibilityConverter}}" Tag="{Binding}" ToolTip="Subir música" Click="BtnMoveItemUp_Click">
                                        <Viewbox Stretch="Uniform"><Path Fill="White" Data="M4772.12 23977.16l5343.04 -3770.04c445.68,-313.07 1041.26,-313.07 1487.07,0l5343.04 3770.04c1102.54,776.75 2507.9,-445.97 1890.51,-1645.04l-6830.11 -13266.82c-480.21,-933.26 -1813.86,-933.26 -2293.91,0l-6830.11 13266.82c-617.43,1199.07 787.97,2421.79 1890.47,1645.04z"/></Viewbox>
                                    </Button>
                                    <Button Grid.Column="1" Style="{StaticResource MoveIconButton}" Visibility="{Binding CanMoveDown, Converter={StaticResource BoolToVisibilityConverter}}" Tag="{Binding}" ToolTip="Descer música" Click="BtnMoveItemDown_Click">
                                        <Viewbox Stretch="Uniform"><Path Fill="White" Data="M16945.29 8609.25l-5343.04 3770.04c-445.68,313.07 -1041.26,313.07 -1487.07,0l-5343.04 -3770.04c-1102.54,-776.75 -2507.9,445.97 -1890.51,1645.04l6830.11 13266.82c480.21,933.26 1813.86,933.26 2293.91,0l6830.11 -13266.82c617.43,-1199.07 -787.97,-2421.79 -1890.47,-1645.04z"/></Viewbox>
                                    </Button>
                                    <TextBlock Grid.Column="2" Text="{Binding PlayMarker}" Foreground="#56E6FF" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{Binding DisplayPosition}" Foreground="#9FB0D0" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,7,0"/>
                                    <TextBlock Grid.Column="4" Text="{Binding MissingMarker}" Foreground="#FBBF24" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" ToolTip="{Binding MissingToolTip}"/>
                                    <TextBlock Grid.Column="5" Text="{Binding Title}" Foreground="White" FontSize="12.5" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" ToolTip="{Binding FilePath}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <UniformGrid Grid.Row="3" Columns="3" Margin="0,9,0,0">
                        <Button Style="{StaticResource ModernButton}" Height="32" Margin="0,0,5,0" Click="BtnRemoveFromSequence_Click"><StackPanel Orientation="Horizontal"><Image Source="assets/icons/Excluir.png" Width="14" Height="14" Margin="0,0,6,0"/><TextBlock Text="Remover item"/></StackPanel></Button>
                        <Button Style="{StaticResource ModernButton}" Height="32" Margin="3,0,3,0" Click="BtnClearMissingItems_Click"><StackPanel Orientation="Horizontal"><Image Source="assets/icons/Limpar.png" Width="14" Height="14" Margin="0,0,6,0"/><TextBlock Text="Limpar inválidas"/></StackPanel></Button>
                        <Button Style="{StaticResource ModernButton}" Height="32" Margin="5,0,0,0" Click="BtnClearSequence_Click"><StackPanel Orientation="Horizontal"><Image Source="assets/icons/Limpar.png" Width="14" Height="14" Margin="0,0,6,0"/><TextBlock Text="Limpar lista"/></StackPanel></Button>
                    </UniformGrid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="12" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="VideoColumn" Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="VideoPanel" Grid.Column="0" Background="#020617" CornerRadius="16" Margin="0,0,14,0" BorderBrush="#203B6B" BorderThickness="1">
                    <Grid>
                        <vlc:VideoView x:Name="VideoView"/>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                            <Image Source="assets/icons/Video.png" Width="36" Height="36" Opacity="0.6" HorizontalAlignment="Center"/>
                            <TextBlock Text="Vídeo" Foreground="#9FB0D0" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <StackPanel Grid.Row="0">
                        <TextBlock x:Name="TxtNowPlaying" Text="Nenhuma música selecionada" Foreground="White" FontSize="17" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="TxtStatus" Text="Aguardando" Foreground="#56E6FF" FontSize="12" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Grid Grid.Row="1" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="BtnRewind10" Grid.Column="0" Style="{StaticResource IconOnlyButton}" Width="34" Height="34" Margin="0,0,8,0" Click="BtnRewind10_Click" ToolTip="Voltar 10 segundos">
                            <Image Source="assets/icons/Voltar_10_Segundos.png" Width="22" Height="22"/>
                        </Button>
                        <Slider x:Name="SliderProgress" Grid.Column="1" Minimum="0" Maximum="100" Value="0" VerticalAlignment="Center" PreviewMouseDown="SliderProgress_PreviewMouseDown" PreviewMouseUp="SliderProgress_PreviewMouseUp"/>
                        <Button x:Name="BtnForward10" Grid.Column="2" Style="{StaticResource IconOnlyButton}" Width="34" Height="34" Margin="8,0,0,0" Click="BtnForward10_Click" ToolTip="Avançar 10 segundos">
                            <Image Source="assets/icons/Avancar_10_Segundos.png" Width="22" Height="22"/>
                        </Button>
                    </Grid>
                    <Grid Grid.Row="2" Margin="0,8,0,0" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="245"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="TxtTime" Grid.Column="0" Text="00:00 / 00:00" Foreground="#DCE7FF" VerticalAlignment="Center"/>

                        <Grid Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34"/>
                                <ColumnDefinition Width="145"/>
                                <ColumnDefinition Width="58"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="BtnMuteVolume" Grid.Column="0" Style="{StaticResource IconOnlyButton}" Width="30" Height="30" Click="BtnMuteVolume_Click" ToolTip="Mutar volume">
                                <Image Source="assets/icons/Mutar_Volume.png" Width="22" Height="22"/>
                            </Button>
                            <Slider x:Name="SliderVolume" Grid.Column="1" Width="140" Minimum="0" Maximum="100" Value="80" VerticalAlignment="Center" ValueChanged="SliderVolume_ValueChanged" PreviewMouseWheel="SliderVolume_PreviewMouseWheel"/>
                            <TextBlock x:Name="TxtVolumePercent" Grid.Column="2" Text="80%" Foreground="#DCE7FF" VerticalAlignment="Center" Margin="8,0,0,0" MinWidth="46"/>
                        </Grid>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                            <Button Style="{StaticResource IconOnlyButton}" Width="60" Height="60" Margin="4,0" Click="BtnPrevious_Click" ToolTip="Anterior"><Image Source="assets/icons/Anterior.png" Width="42" Height="42"/></Button>
                            <Button x:Name="BtnPlayPause" Style="{StaticResource IconOnlyButton}" Width="72" Height="72" Margin="8,0" Click="BtnPlayPause_Click" ToolTip="Play/Pause"><Image Source="assets/icons/Play.png" Width="52" Height="52"/></Button>
                            <Button Style="{StaticResource IconOnlyButton}" Width="60" Height="60" Margin="4,0" Click="BtnStop_Click" ToolTip="Parar"><Image Source="assets/icons/Parar.png" Width="42" Height="42"/></Button>
                            <Button Style="{StaticResource IconOnlyButton}" Width="60" Height="60" Margin="4,0" Click="BtnNext_Click" ToolTip="Próxima"><Image Source="assets/icons/Proxima.png" Width="42" Height="42"/></Button>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="16,0,0,0">
                            <TextBlock Text="Ao finalizar" Foreground="#9FB0D0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="ComboPlayMode" Width="160" Height="30" HorizontalAlignment="Left" SelectedIndex="0">
                                <ComboBoxItem Content="Parar"/><ComboBoxItem Content="Tocar próxima"/><ComboBoxItem Content="Tocar todas"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,8,0,4">
                        <Button x:Name="BtnToggleVideo" Style="{StaticResource ModernButton}" Width="125" Height="34" Margin="6,0,4,0" Visibility="Collapsed" Click="BtnToggleVideo_Click"><StackPanel Orientation="Horizontal"><Image Source="assets/icons/Video.png" Width="16" Height="16" Margin="0,0,7,0"/><TextBlock Text="Mostrar vídeo"/></StackPanel></Button>
                        <Button x:Name="BtnFullscreenVideo" Style="{StaticResource ModernButton}" Width="118" Height="34" Margin="6,0,0,0" Visibility="Collapsed" Click="BtnFullscreenVideo_Click"><StackPanel Orientation="Horizontal"><Image Source="assets/icons/TelaCheia.png" Width="16" Height="16" Margin="0,0,7,0"/><TextBlock Text="Tela cheia"/></StackPanel></Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>

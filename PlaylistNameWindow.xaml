<Window x:Class="AlphaPlay.PlaylistNameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nome da sequência"
        Icon="assets/brand/app_icon.ico"
        Height="210"
        Width="430"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#070B1A">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1A2744"/>
            <Setter Property="BorderBrush" Value="#314061"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#0C1426"/>
            <Setter Property="BorderBrush" Value="#00D9FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>
    </Window.Resources>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Digite o nome da sequência:"
                   Foreground="White"
                   FontSize="16"
                   FontWeight="SemiBold"/>

        <TextBox x:Name="TxtPlaylistName"
                 Grid.Row="1"
                 Height="36"
                 FontSize="15"
                 Padding="10,6"
                 Margin="0,12,0,0"/>

        <TextBlock Grid.Row="2"
                   Text="Exemplo: Culto de sábado, Ensaio, Programa JA"
                   Foreground="#9FB0D0"
                   FontSize="12"
                   Margin="0,8,0,0"/>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Cancelar"
                    Width="90"
                    Height="32"
                    Margin="0,0,8,0"
                    Click="BtnCancel_Click"/>
            <Button Content="Salvar"
                    Width="90"
                    Height="32"
                    Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="AlphaPlay.RemoteControlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Controle remoto por celular"
        Icon="assets/brand/app_icon.ico"
        Height="720"
        Width="640"
        MinHeight="520"
        MinWidth="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#070B1A">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#0C1426"/>
            <Setter Property="BorderBrush" Value="#26365F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1A2744"/>
            <Setter Property="BorderBrush" Value="#314061"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#22365E"/>
                                <Setter Property="BorderBrush" Value="#00D9FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#10203B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RemoteToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="118"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Track"
                                    Background="#7F1D1D"
                                    BorderBrush="#EF4444"
                                    BorderThickness="1"
                                    CornerRadius="21"/>
                            <TextBlock x:Name="OffText"
                                       Text="OFF"
                                       Foreground="#FEE2E2"
                                       FontWeight="Bold"
                                       FontSize="13"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="0,0,19,0"/>
                            <TextBlock x:Name="OnText"
                                       Text="ON"
                                       Foreground="#DCFCE7"
                                       FontWeight="Bold"
                                       FontSize="13"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       Margin="22,0,0,0"
                                       Opacity="0"/>
                            <Ellipse x:Name="Thumb"
                                     Width="34"
                                     Height="34"
                                     Fill="#FFFFFF"
                                     HorizontalAlignment="Left"
                                     Margin="4,0,0,0">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.35"/>
                                </Ellipse.Effect>
                            </Ellipse>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#14532D"/>
                                <Setter TargetName="Track" Property="BorderBrush" Value="#22C55E"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,4,0"/>
                                <Setter TargetName="OffText" Property="Opacity" Value="0"/>
                                <Setter TargetName="OnText" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="18"
            Padding="18"
            Background="#121A2E"
            BorderBrush="#223055"
            BorderThickness="1"
            CornerRadius="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Controle remoto por celular"
                           FontSize="24"
                           FontWeight="Bold"/>
                <TextBlock Text="Controle o AlphaPlay pelo navegador do celular, desde que o computador e o celular estejam conectados à mesma rede."
                           Foreground="#9FB0D0"
                           TextWrapping="Wrap"
                           Margin="0,6,0,0"/>
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,22,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtRemoteTitle"
                               Text="Controle remoto: OFF"
                               FontSize="16"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Arraste ou clique na chave para ativar/desativar."
                               Foreground="#9FB0D0"
                               FontSize="12"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <ToggleButton x:Name="ToggleRemoteControl"
                              Grid.Column="1"
                              Style="{StaticResource RemoteToggleStyle}"
                              Checked="ToggleRemoteControl_Changed"
                              Unchecked="ToggleRemoteControl_Changed"/>
            </Grid>

            <ScrollViewer Grid.Row="2"
                          Margin="0,22,0,0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="False">
                <Border Padding="14"
                        Background="#0C1426"
                        BorderBrush="#26365F"
                        BorderThickness="1"
                        CornerRadius="14">
                    <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="142"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Status:" Foreground="#9FB0D0" Margin="0,0,0,12"/>
                    <TextBlock x:Name="TxtStatus" Grid.Row="0" Grid.Column="1" Text="Desativado" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="IP do computador:" Foreground="#9FB0D0" Margin="0,0,0,12"/>
                    <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="TxtIp" Grid.Column="0" Text="Não encontrado" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button x:Name="BtnRefreshIp" Grid.Column="1" Content="Atualizar IP" Margin="8,0,0,0" Click="BtnRefreshIp_Click"/>
                    </Grid>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Porta:" Foreground="#9FB0D0" Margin="0,0,0,12"/>
                    <Grid Grid.Row="2" Grid.Column="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtPort"
                                 Grid.Column="0"
                                 MaxLength="5"
                                 PreviewTextInput="TxtPort_PreviewTextInput"
                                 DataObject.Pasting="TxtPort_Pasting"/>
                        <Button x:Name="BtnSavePort" Grid.Column="1" Content="Salvar" Margin="8,0,0,0" Click="BtnSavePort_Click"/>
                        <TextBlock Grid.Column="2" Text="1024 a 65535" Foreground="#9FB0D0" FontSize="12" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </Grid>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Link de acesso:" Foreground="#9FB0D0" Margin="0,0,0,18"/>
                    <TextBlock x:Name="TxtLink" Grid.Row="3" Grid.Column="1" Text="Controle remoto desativado" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,18"/>

                    <Border Grid.Row="4" Grid.ColumnSpan="2" Height="1" Background="#26365F" Margin="0,0,0,14"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Segurança:" Foreground="#9FB0D0" Margin="0,0,0,12"/>
                    <StackPanel Grid.Row="5" Grid.Column="1" Margin="0,0,0,12">
                        <CheckBox x:Name="ChkRequirePin"
                                  Content="Exigir PIN para acessar pelo celular"
                                  Checked="ChkRequirePin_Changed"
                                  Unchecked="ChkRequirePin_Changed"/>
                        <TextBlock Text="Opcional. Quando ativado, o celular pede o PIN antes de liberar os controles."
                                   Foreground="#9FB0D0"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="PIN atual:" Foreground="#9FB0D0"/>
                    <Grid Grid.Row="6" Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="TxtPin" Grid.Column="0" Text="----" FontWeight="Bold" FontSize="18" VerticalAlignment="Center"/>
                        <Button x:Name="BtnGeneratePin" Grid.Column="1" Content="Gerar novo PIN" Margin="8,0,0,0" Click="BtnGeneratePin_Click"/>
                        <TextBlock x:Name="TxtPinStatus" Grid.Column="2" Text="PIN não exigido" Foreground="#9FB0D0" FontSize="12" Margin="10,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap"/>
                    </Grid>

                    <Border Grid.Row="7" Grid.ColumnSpan="2" Height="1" Background="#26365F" Margin="0,16,0,14"/>

                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Diagnóstico:" Foreground="#9FB0D0" Margin="0,0,0,12"/>
                    <StackPanel Grid.Row="8" Grid.Column="1" Margin="0,0,0,12">
                        <TextBlock Text="Use estes testes quando o celular não conseguir abrir o link do AlphaPlay."
                                   Foreground="#9FB0D0"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <TextBlock Grid.Row="9" Grid.Column="0" Text="Testes:" Foreground="#9FB0D0" Margin="0,0,0,12"/>
                    <WrapPanel Grid.Row="9" Grid.Column="1" Margin="0,0,0,12">
                        <Button x:Name="BtnTestServer" Content="Testar servidor" Width="130" Margin="0,0,8,8" Click="BtnTestServer_Click"/>
                        <Button x:Name="BtnCheckPort" Content="Verificar porta" Width="130" Margin="0,0,8,8" Click="BtnCheckPort_Click"/>
                        <Button x:Name="BtnCopyDiagnostics" Content="Copiar informações" Width="150" Margin="0,0,8,8" Click="BtnCopyDiagnostics_Click"/>
                        <Button x:Name="BtnFirewallHelp" Content="Ajuda firewall" Width="125" Margin="0,0,0,8" Click="BtnFirewallHelp_Click"/>
                    </WrapPanel>

                    <TextBlock Grid.Row="10" Grid.Column="0" Text="Resultado:" Foreground="#9FB0D0"/>
                    <TextBlock x:Name="TxtDiagnosticInfo"
                               Grid.Row="10"
                               Grid.Column="1"
                               Text="Aguardando teste."
                               Foreground="#9FB0D0"
                               TextWrapping="Wrap"/>
                    </Grid>
                </Border>
            </ScrollViewer>

            <Grid Grid.Row="3" Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button x:Name="BtnCopyLink"
                            Content="Copiar link"
                            Width="120"
                            IsEnabled="False"
                            Click="BtnCopyLink_Click"/>
                    <Button x:Name="BtnShowQrCode"
                            Content="Mostrar QR Code"
                            Width="145"
                            Margin="8,0,0,0"
                            IsEnabled="False"
                            Click="BtnShowQrCode_Click"/>
                </StackPanel>

                <Button x:Name="BtnClose"
                        Grid.Column="1"
                        Content="Fechar"
                        Width="100"
                        Click="BtnClose_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>

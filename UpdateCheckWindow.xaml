<Window MinHeight="520" x:Class="AlphaPlay.UpdateCheckWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Procurar atualização" Height="420" Width="520"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        Background="#07101F">
    <Window.Resources>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1A3767"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="18" Padding="22" CornerRadius="18" Background="#0D172A" BorderBrush="#253C6B" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Procurar atualização" Foreground="White" FontSize="24" FontWeight="Bold"/>
                <TextBlock Text="O AlphaPlay vai consultar a última versão publicada no GitHub." Foreground="#B7C8E8" FontSize="13" TextWrapping="Wrap" Margin="0,8,0,0"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" CanContentScroll="False">
            <Border Margin="0,22,0,18" Padding="16" CornerRadius="14" Background="#07101F" BorderBrush="#263B64" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Status" Foreground="#8FB2FF" FontSize="12"/>
                    <TextBlock x:Name="TxtStatus" Text="Procurando atualização..." Foreground="White" FontSize="18" FontWeight="Bold" TextWrapping="Wrap" Margin="0,4,0,16"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Versão atual:" Foreground="#AFC0DE"/>
                        <TextBlock x:Name="TxtCurrentVersion" Grid.Column="1" Text="-" Foreground="White" FontWeight="SemiBold"/>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Versão disponível:" Foreground="#AFC0DE"/>
                        <TextBlock x:Name="TxtLatestVersion" Grid.Column="1" Text="-" Foreground="White" FontWeight="SemiBold"/>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Instalador:" Foreground="#AFC0DE"/>
                        <TextBlock x:Name="TxtInstaller" Grid.Column="1" Text="-" Foreground="White" FontWeight="SemiBold" TextWrapping="Wrap"/>
                    </Grid>

                    <TextBlock x:Name="TxtMessage" Foreground="#B7C8E8" TextWrapping="Wrap" Margin="0,14,0,0"/>
                </StackPanel>
            </Border>
            </ScrollViewer>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnRetry" Grid.Column="0" Style="{StaticResource ActionButton}" Width="130" HorizontalAlignment="Left" Content="Verificar de novo" Click="BtnRetry_Click"/>
                <Button x:Name="BtnDownload" Grid.Column="1" Style="{StaticResource ActionButton}" Width="160" Margin="8,0,0,0" Background="#0B8F5A" Content="Baixar atualização" Click="BtnDownload_Click" Visibility="Collapsed"/>
                <Button Grid.Column="2" Style="{StaticResource ActionButton}" Width="110" Margin="8,0,0,0" Content="Fechar" Click="BtnClose_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
